<idea-plugin url="https://github.com/MarcinOrlowski/idea-glowstick-mhl">
    <!--
      Metadata source of truth is gradle.properties + build.gradle.kts.
      `patchPluginXml` injects <name>, <version>, <description>, <change-notes>,
      and <idea-version since-build> into the PACKAGED plugin.xml at build time.
      Do not add those tags here - keep only structural declarations below.
    -->
    <id>com.marcinorlowski.glowstick</id>
    <vendor email="mail@marcinOrlowski.com"
            url="https://github.com/MarcinOrlowski/">Marcin Orlowski
    </vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Stores color setting per project -->
        <projectService
                serviceInterface="com.marcinorlowski.glowstick.ProjectColorSettings"
                serviceImplementation="com.marcinorlowski.glowstick.ProjectColorSettings"/>

        <!-- Settings/Preferences → Appearance & Behavior → GlowStick MHL -->
        <projectConfigurable
                instance="com.marcinorlowski.glowstick.ProjectColorConfigurable"
                id="com.marcinorlowski.glowstick.settings"
                displayName="GlowStick Frame"
                parentId="appearance"/>

        <!-- Draws the frame on project open AND for already-open projects on plugin install -->
        <postStartupActivity
                implementation="com.marcinorlowski.glowstick.ProjectColorStartupActivity"/>
    </extensions>

    <applicationListeners>
        <!-- Applies color when the window gains focus or when the project changes -->
        <listener
                class="com.marcinorlowski.glowstick.ProjectColorActivationListener"
                topic="com.intellij.openapi.application.ApplicationActivationListener"/>
        <!-- Draw for open projects when the plugin is installed into a running IDE -->
        <listener
                class="com.marcinorlowski.glowstick.ProjectColorPluginListener"
                topic="com.intellij.ide.plugins.DynamicPluginListener"/>
    </applicationListeners>

    <actions>
        <action id="com.marcinorlowski.glowstick.ToggleColorFrameAction"
                class="com.marcinorlowski.glowstick.ToggleColorFrameAction"
                text="Draw GlowStick window frame"
                description="Toggles drawing of window's colored frame"
                icon="/logo.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

    </actions>
</idea-plugin>
